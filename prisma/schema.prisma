// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String           @id @default(uuid())
  username        String           @unique
  password        String           // Hash SHA-256
  name            String
  role            String           // "Admin", "Recepción", "Doctor"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
}

model Patient {
  id                 String           @id @default(uuid())
  firstName          String
  lastName           String
  phone1             String
  phone2             String
  gender             String           // "Masculino", "Femenino", "Otro"
  status             String           @default("Activo") // "Activo", "Inactivo", "En tratamiento"
  rx                 Boolean          @default(false)
  therapyId          String?
  therapy            Therapy?         @relation(fields: [therapyId], references: [id])
  therapySubcategory String?          // For Reset: Tratamiento E, Tratamiento B, Tratamiento F
  genderCode         String?          // Keep for backwards compatibility
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  appointments       Appointment[]
  clinicalRecords    ClinicalRecord[]
}

model Therapy {
  id           String        @id
  name         String
  description  String?
  price        Float
  color        String        // Color hex code or Tailwind class name
  appointments Appointment[]
  patients     Patient[]
}

model Appointment {
  id                 String    @id @default(uuid())
  patientId          String
  patient            Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapyId          String
  therapy            Therapy   @relation(fields: [therapyId], references: [id])
  therapySubcategory String?   // "Tratamiento E", "Tratamiento B", "Tratamiento F" (for Reset)
  date               String    // YYYY-MM-DD
  timeSlot           String    // e.g. "07:00", "07:15"
  consultorio        String    // "A", "B", "C", "D"
  status             String    // "Agendada", "Confirmada", "Cancelada"
  paymentStatus      String    // "Pendiente", "Parcial", "Pagado"
  tipo               String    @default("COT") // e.g. COT
  rx                 Boolean   @default(false)
  googleEventId      String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  payments           Payment[]
  userId             String?   // Attending user/doctor
  user               User?     @relation(fields: [userId], references: [id])

  @@unique([date, timeSlot, consultorio])
}

model Payment {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Float
  method        String      // "Efectivo", "Tarjeta", "Transferencia"
  createdAt     DateTime    @default(now())
  notes         String?
}

model ClinicalRecord {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId    String   // Attending doctor/user
  user      User     @relation(fields: [userId], references: [id])
  date      String   // YYYY-MM-DD
  notes     String   // clinical notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleBlock {
  id          String   @id @default(uuid())
  date        String   // YYYY-MM-DD
  timeSlot    String?  // Start time slot, e.g., "08:00" or null if whole day/half day
  type        String   // "15_MIN", "HOUR", "HALF_DAY", "FULL_DAY"
  halfDayType String?  // "Mañana" or "Tarde"
  consultorio String   // "A", "B", "C", "D" or "TODOS"
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoogleAuth {
  id           String   @id @default("default")
  accessToken  String?
  refreshToken String?
  expiryDate   String?  // Saved as string due to SQLite BigInt limit
  updatedAt    DateTime @updatedAt
}

model AppConfig {
  id               String @id @default("default")
  whatsappTemplate String @default("Hola {paciente}, te recordamos tu cita de {terapia} el {fecha} a las {hora}. Confírmanos por este medio.")
}

